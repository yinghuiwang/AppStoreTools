# App Store Connect API 配置
# 从 https://appstoreconnect.apple.com/access/integrations/api 获取

# Issuer ID (团队级别，所有 API Key 共享)
ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Key ID (创建 API Key 时生成)
KEY_ID=XXXXXXXXXX

# .p8 私钥文件路径 (下载的 AuthKey_XXXXXXXXXX.p8)
KEY_FILE=AuthKey_${KEY_ID}.p8

# App 的 Apple ID (在 App Store Connect 的 App 信息页面可以找到)
APP_ID=1234567890
